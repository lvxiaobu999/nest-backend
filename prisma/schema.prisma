generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Permission {
  id         String   @id @default(uuid())
  name       String   @unique
  code       String   @unique
  remark     String?
  enabled    Boolean  @default(true)
  menuId     String?
  menu       Menu?    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  roles      Role[]
  createTime DateTime @default(now())
  updateTime DateTime @updatedAt

  @@index([menuId])
  @@map("permissions")
}

model Menu {
  id         String       @id @default(uuid())
  // Root menus should keep parentId as null to avoid self-relation FK errors.
  parentId   String?
  path       String
  title      String
  icon       String?
  order      Int?         @default(0)
  keepAlive  Boolean?     @default(false)
  hidden     Boolean?     @default(false)
  isLogin    Boolean?     @default(true)
  disabled   Boolean?     @default(false)
  enabled    Boolean      @default(true)
  children   Menu[]       @relation("MenuToMenu")
  parent     Menu?        @relation("MenuToMenu", fields: [parentId], references: [id], onDelete: Cascade)
  permissions Permission[]
  roles      Role[]
  createTime DateTime     @default(now())
  updateTime DateTime     @updatedAt

  @@index([parentId])
  @@map("menus")
}

model Role {
  id           String       @id @default(uuid())
  name         String       @unique
  code         String       @unique
  desc         String?
  enabled      Boolean      @default(true)
  users        User[]
  menus        Menu[]
  permissions  Permission[]
  createTime   DateTime     @default(now())
  updateTime   DateTime     @updatedAt

  @@map("roles")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  password     String
  isSuperAdmin Boolean?     @default(true)
  roleId       String?
  role         Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  nickname     String
  enabled      Boolean      @default(true)
  remark       String?
  createTime   DateTime @default(now())
  updateTime   DateTime @updatedAt

  @@index([roleId])
  @@map("users")
}

model DashboardCoreMetric {
  id                String   @id @default(uuid())
  metricDate        DateTime @unique @db.Date
  todayVisits       Int      @default(0)
  blockedCount      Int      @default(0)
  payUsers          Int      @default(0)
  payOrders         Int      @default(0)
  totalVisits       Int      @default(0)
  payConversionRate Decimal  @default(0) @db.Decimal(5, 2)
  createTime        DateTime @default(now())
  updateTime        DateTime @updatedAt

  @@map("dashboard_core_metrics")
}

model DashboardDomain {
  id         String                @id @default(uuid())
  name       String                @unique
  enabled    Boolean               @default(true)
  stats      DashboardDomainStat[]
  createTime DateTime              @default(now())
  updateTime DateTime              @updatedAt

  @@map("dashboard_domains")
}

model DashboardDomainStat {
  id         String          @id @default(uuid())
  domainId   String
  statDate   DateTime        @db.Date
  visits     Int             @default(0)
  payments   Int             @default(0)
  domain     DashboardDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  createTime DateTime        @default(now())
  updateTime DateTime        @updatedAt

  @@unique([domainId, statDate])
  @@index([domainId, statDate])
  @@index([statDate])
  @@map("dashboard_domain_stats")
}

model DashboardSystemSnapshot {
  id           String   @id @default(uuid())
  reportTime   DateTime @default(now())
  serverStatus String
  alertCount   Int      @default(0)
  createTime   DateTime @default(now())
  updateTime   DateTime @updatedAt

  @@index([reportTime])
  @@map("dashboard_system_snapshots")
}
